---
import { getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import RelatedServices from '../../components/RelatedServices.astro';
import Faq from '../../components/Faq.astro';
import ContactCTA from '../../components/ContactCTA.astro';

const entry = await getEntry('de', 'fx-options');
if (!entry) throw new Error('Content not found: de/fx-options');
const { Content } = await entry.render();
const data = entry.data;
---
<BaseLayout
  title={data.title}
  description={data.description}
  keywords={data.keywords}
  lang="de"
  navKey={data.navKey}
>
  <Hero eyebrow={data.eyebrow} headline={data.headline} subheadline={data.subheadline} />

  <article class="service-content">
    <div class="container">
      <Content />
    </div>
  </article>

  {data.related && data.related.length > 0 && (
    <RelatedServices lang="de" relatedKeys={data.related} />
  )}

  {data.faq && data.faq.length > 0 && (
    <Faq lang="de" items={data.faq} />
  )}

  <ContactCTA lang="de" />
</BaseLayout>

<style>
  .service-content {
    padding: 80px 32px 100px;
    background: var(--bg, #fff);
  }
  .service-content .container {
    max-width: 880px;
    margin: 0 auto;
    font-size: 17px;
    line-height: 1.75;
    color: var(--ink, #1f2d4a);
  }
  .service-content :global(h2) {
    font-family: 'Archivo', sans-serif;
    font-size: clamp(26px, 3vw, 32px);
    font-weight: 700;
    color: var(--navy, #0a1e3a);
    margin: 56px 0 20px;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  .service-content :global(h2:first-child) { margin-top: 0; }
  .service-content :global(h3) {
    font-family: 'Archivo', sans-serif;
    font-size: 20px;
    font-weight: 600;
    color: var(--navy, #0a1e3a);
    margin: 32px 0 12px;
  }
  .service-content :global(p) {
    margin: 0 0 18px;
    color: var(--ink-2, #3d5275);
  }
  .service-content :global(strong) {
    color: var(--navy, #0a1e3a);
    font-weight: 600;
  }
  .service-content :global(a) {
    color: var(--blue, #2563eb);
    text-decoration: none;
    border-bottom: 1px solid rgba(37,99,235,.3);
    transition: border-color .15s;
  }
  .service-content :global(a:hover) {
    border-bottom-color: var(--blue, #2563eb);
  }
  .service-content :global(ul) {
    margin: 0 0 18px;
    padding-left: 24px;
    color: var(--ink-2, #3d5275);
  }
  .service-content :global(li) {
    margin-bottom: 8px;
  }
  @media (max-width: 980px) {
    .service-content { padding: 60px 24px 80px; }
  }
</style>
