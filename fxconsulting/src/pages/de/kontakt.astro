---
import { getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ContactForm from '../../components/ContactForm.astro';

const entry = await getEntry('de', 'kontakt');
if (!entry) throw new Error('Content not found: de/kontakt');
const { Content } = await entry.render();
const data = entry.data;
---
<BaseLayout
  title={data.title}
  description={data.description}
  keywords={data.keywords}
  lang="de"
  navKey={data.navKey}
>
  <Hero eyebrow={data.eyebrow} headline={data.headline} subheadline={data.subheadline} variant="centered" />

  <section class="contact-section">
    <div class="contact-grid">
      <div class="contact-info">
        <article class="prose">
          <Content />
        </article>

        <div class="contact-card">
          <h3>FX ALPHA eBusiness Consulting GmbH</h3>
          <p>
            Schwalbacher Strasse 30a<br />
            65510 Idstein<br />
            Deutschland
          </p>
          <p>
            <strong>E-Mail:</strong>
            <a href="mailto:info@fxconsulting.de">info@fxconsulting.de</a><br />
            <strong>Telefon (DE):</strong>
            <a href="tel:+4961269585652">+49 6126 958 56 52</a>
          </p>
          <p class="meta">HRB 33846 · Wiesbaden</p>
        </div>
      </div>

      <ContactForm lang="de" />
    </div>
  </section>
</BaseLayout>

<style>
  .contact-section {
    padding: 60px 32px 100px;
    background: var(--bg, #fff);
  }
  .contact-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }
  .contact-info { display: flex; flex-direction: column; gap: 32px; }
  .prose {
    color: var(--ink-2, #3d5275);
    font-size: 16px;
    line-height: 1.7;
  }
  .prose :global(p) { margin: 0 0 16px; }
  .prose :global(a) {
    color: var(--blue, #2563eb);
    text-decoration: none;
    border-bottom: 1px solid rgba(37,99,235,.3);
  }
  .contact-card {
    background: var(--bg-2, #f4f7fb);
    border: 1px solid var(--line, #dbe3ed);
    border-radius: 12px;
    padding: 28px 32px;
  }
  .contact-card h3 {
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: 16px;
    color: var(--navy, #0a1e3a);
    margin: 0 0 12px;
    letter-spacing: -0.01em;
  }
  .contact-card p {
    margin: 0 0 14px;
    color: var(--ink-2, #3d5275);
    font-size: 15px;
    line-height: 1.65;
  }
  .contact-card p:last-child { margin-bottom: 0; }
  .contact-card a {
    color: var(--blue, #2563eb);
    text-decoration: none;
  }
  .contact-card a:hover { text-decoration: underline; }
  .contact-card strong { color: var(--navy, #0a1e3a); font-weight: 600; }
  .contact-card .meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--ink-3, #6b7c9c);
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--line, #dbe3ed);
  }
  @media (max-width: 980px) {
    .contact-grid { grid-template-columns: 1fr; gap: 40px; }
    .contact-section { padding: 40px 24px 80px; }
  }
</style>
