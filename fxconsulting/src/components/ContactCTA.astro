---
import { t, pathMap, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const contactPath = pathMap.contact[lang];
---
<section class="contact-cta">
  <div class="container">
    <h2>{t(lang, 'sections.contact-cta-headline')}</h2>
    <p>{t(lang, 'sections.contact-cta-text')}</p>
    <a href={contactPath} class="cta">{t(lang, 'cta.startConversation')}</a>
  </div>
</section>

<style>
  .contact-cta {
    padding: 120px 32px;
    background: var(--navy, #0a1e3a);
    color: #fff;
    text-align: center;
  }
  .contact-cta .container { max-width: 720px; margin: 0 auto; }
  .contact-cta h2 {
    font-family: 'Archivo', sans-serif;
    font-size: clamp(28px, 3.6vw, 44px);
    font-weight: 700;
    color: #fff;
    margin-bottom: 20px;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }
  .contact-cta p {
    color: rgba(255,255,255,.7);
    font-size: 17px;
    max-width: 560px;
    margin: 0 auto 40px;
    line-height: 1.55;
  }
  .contact-cta .cta {
    background: var(--blue-2, #3b82f6);
    color: #fff;
    border-color: var(--blue-2, #3b82f6);
  }
  .contact-cta .cta:hover {
    background: #fff;
    color: var(--navy, #0a1e3a);
    border-color: #fff;
  }
  @media (max-width: 980px) {
    .contact-cta { padding: 80px 24px; }
  }
</style>
