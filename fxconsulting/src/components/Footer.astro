---
import { t, pathMap, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const homePath = pathMap.home[lang];
---
<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <a href={homePath} class="brand">
        <span class="mark" role="img" aria-label="FX Alpha"></span>
        {t(lang, 'site.name')} <small>{t(lang, 'site.subtitle')}</small>
      </a>
      <p>{t(lang, 'footer.about')}</p>
      <a href={pathMap.insights[lang]} class="footer-insights-link">{t(lang, 'nav.insights')} →</a>
    </div>
    <div class="footer-col">
      <h5>{t(lang, 'footer.address')}</h5>
      <p>FX ALPHA eBusiness Consulting GmbH<br />Schwalbacher Strasse 30a<br />65510 Idstein<br />Germany</p>
    </div>
    <div class="footer-col">
      <h5>{t(lang, 'footer.legal')}</h5>
      <a href={pathMap.imprint[lang]}>{t(lang, 'footer.imprint')}</a>
      <a href={pathMap.privacy[lang]}>{t(lang, 'footer.privacy')}</a>
      <a href={pathMap.disclaimer[lang]}>{t(lang, 'footer.disclaimer')}</a>
      <a href={pathMap.cookies[lang]}>{t(lang, 'footer.cookies')}</a>
      <p style="margin-top:14px">HRB 33846 · Wiesbaden</p>
    </div>
  </div>
  <div class="footer-bottom">
    <span>{t(lang, 'footer.copyright')}</span>
    <div>
      <a href="mailto:info@fxconsulting.de">info@fxconsulting.de</a>
    </div>
  </div>
</footer>

<style>
  .footer-insights-link {
    display: inline-block;
    margin-top: 14px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: .04em;
    color: var(--blue-2, #3b82f6);
    text-decoration: none;
  }
  .footer-insights-link:hover { color: #fff; }
</style>
