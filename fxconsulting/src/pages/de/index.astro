---
import { getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, pathMap } from '../../i18n/ui';

const entry = await getEntry('de', 'home');
if (!entry) throw new Error('Content not found: de/home');
const data = entry.data;
const lang = 'de';
---
<BaseLayout
  title={data.title}
  description={data.description}
  keywords={data.keywords}
  lang={lang}
  navKey="home"
>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <div class="eyebrow"><span class="dot"></span>{data.eyebrow}</div>
      <h1 class="display" set:html={data.headline}></h1>
      <p class="lede" set:html={data.subheadline}></p>
      <div class="hero-actions">
        <a href={pathMap.privateEquity[lang]} class="cta">{t(lang, 'cta.whatWeDo')}</a>
        <a href={pathMap.contact[lang]} class="cta-ghost">{t(lang, 'cta.contact')}</a>
      </div>
    </div>
  </section>

  <!-- Story-Sektionen -->
  {data.stories && data.stories.map((story, idx) => (
    <section class={`story-section ${idx % 2 === 1 ? 'alt' : ''}`}>
      <div class="story-inner">
        <div class="story-eyebrow">{story.eyebrow}</div>
        <h2 class="story-headline">
          <span class="x">{story.headlineX}</span>
          <span class="amp">&amp;</span>
          <span class="y">{story.headlineY}</span>
        </h2>
        <p class="story-intro">{story.intro}</p>
        <div class="story-columns">
          {story.columns.map((col) => (
            <div class="story-col">
              <div class="col-label">{col.label}</div>
              <p>{col.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Klientel -->
  {data.clientTypes && (
    <section class="clients">
      <div class="clients-inner">
        <div class="eyebrow"><span class="dot"></span>Klientel</div>
        <h2 class="section-headline">Für wen wir arbeiten.</h2>
        <div class="clients-grid">
          {data.clientTypes.map((c) => (
            <div class="client-card">
              <h3>{c.title}</h3>
              <p>{c.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Service-Teaser -->
  {data.serviceTeasers && (
    <section class="services-teaser">
      <div class="services-inner">
        <div class="eyebrow"><span class="dot"></span>Leistungen</div>
        <h2 class="section-headline">Was wir tun.</h2>
        <div class="services-grid">
          {data.serviceTeasers.map((s) => (
            <a href={pathMap[s.linkKey][lang]} class="service-card">
              <div class="service-number">{s.number}</div>
              <h3>{s.title}</h3>
              <p>{s.text}</p>
              <span class="service-more">{t(lang, 'cta.learnMore')} →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Final CTA -->
  <section class="contact-cta">
    <div class="container">
      <h2>{t(lang, 'sections.contact-cta-headline')}</h2>
      <p>{t(lang, 'sections.contact-cta-text')}</p>
      <a href={pathMap.contact[lang]} class="cta">{t(lang, 'cta.startConversation')}</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Story-Sektionen */
  .story-section { padding: 100px 32px; background: var(--bg, #fff); border-top: 1px solid var(--line, #dbe3ed); }
  .story-section.alt { background: var(--bg-2, #f4f7fb); }
  .story-inner { max-width: 1100px; margin: 0 auto; }
  .story-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--blue, #2563eb);
    text-transform: uppercase;
    letter-spacing: .08em;
    margin-bottom: 24px;
  }
  .story-headline {
    font-family: 'Archivo', sans-serif;
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 800;
    color: var(--navy, #0a1e3a);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin-bottom: 28px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px 20px;
    align-items: baseline;
  }
  .story-headline .amp {
    color: var(--blue, #2563eb);
    font-weight: 500;
    font-style: italic;
  }
  .story-intro {
    font-size: 18px;
    color: var(--ink-2, #3d5275);
    max-width: 720px;
    line-height: 1.65;
    margin-bottom: 56px;
  }
  .story-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }
  .story-col .col-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--blue, #2563eb);
    letter-spacing: .04em;
    margin-bottom: 12px;
  }
  .story-col p {
    color: var(--ink-2, #3d5275);
    font-size: 16px;
    line-height: 1.7;
  }

  /* Klientel */
  .clients { padding: 120px 32px; background: var(--navy, #0a1e3a); color: #fff; }
  .clients-inner { max-width: 1280px; margin: 0 auto; }
  .clients .eyebrow { color: rgba(255,255,255,.6); }
  .clients .eyebrow .dot { background: var(--blue-2, #3b82f6); }
  .clients .section-headline { color: #fff; }
  .clients-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 56px;
  }
  .client-card {
    padding: 28px 26px;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 12px;
  }
  .client-card h3 {
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: 17px;
    margin-bottom: 8px;
    color: #fff;
    letter-spacing: -0.01em;
  }
  .client-card p { color: rgba(255,255,255,.6); font-size: 14px; line-height: 1.55; }

  /* Services Teaser */
  .services-teaser { padding: 120px 32px; background: var(--bg, #fff); }
  .services-inner { max-width: 1280px; margin: 0 auto; }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 56px;
  }
  .service-card {
    padding: 40px 36px;
    background: var(--bg-2, #f4f7fb);
    border: 1px solid var(--line, #dbe3ed);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: all .25s;
    display: flex;
    flex-direction: column;
  }
  .service-card:hover {
    border-color: var(--blue, #2563eb);
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(10,30,58,.08);
  }
  .service-number {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--blue, #2563eb);
    letter-spacing: .04em;
    margin-bottom: 16px;
  }
  .service-card h3 {
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: 22px;
    color: var(--navy, #0a1e3a);
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }
  .service-card p {
    color: var(--ink-2, #3d5275);
    font-size: 15px;
    line-height: 1.6;
    flex-grow: 1;
    margin-bottom: 20px;
  }
  .service-more {
    color: var(--blue, #2563eb);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: .04em;
  }

  .section-headline {
    font-family: 'Archivo', sans-serif;
    font-weight: 800;
    font-size: clamp(32px, 4vw, 48px);
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--navy, #0a1e3a);
  }

  /* Hero Actions */
  .hero-actions { display: flex; gap: 14px; margin-top: 40px; flex-wrap: wrap; }
  .cta-ghost {
    padding: 14px 28px;
    border: 1px solid var(--line, #dbe3ed);
    background: transparent;
    color: var(--navy, #0a1e3a);
    border-radius: 8px;
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    transition: all .2s;
  }
  .cta-ghost:hover { border-color: var(--navy, #0a1e3a); background: var(--bg-2, #f4f7fb); }

  /* Final CTA */
  .contact-cta {
    padding: 120px 32px;
    background: var(--navy, #0a1e3a);
    color: #fff;
    text-align: center;
  }
  .contact-cta .container { max-width: 720px; margin: 0 auto; }
  .contact-cta h2 {
    font-family: 'Archivo', sans-serif;
    font-size: clamp(28px, 3.6vw, 44px);
    font-weight: 700;
    color: #fff;
    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }
  .contact-cta p {
    color: rgba(255,255,255,.7);
    font-size: 17px;
    max-width: 560px;
    margin: 0 auto 40px;
    line-height: 1.55;
  }
  .contact-cta .cta {
    background: var(--blue-2, #3b82f6);
    color: #fff;
    border-color: var(--blue-2, #3b82f6);
  }
  .contact-cta .cta:hover {
    background: #fff;
    color: var(--navy, #0a1e3a);
    border-color: #fff;
  }

  @media (max-width: 980px) {
    .story-section, .clients, .services-teaser { padding: 80px 24px; }
    .story-columns { grid-template-columns: 1fr; gap: 32px; }
    .clients-grid { grid-template-columns: 1fr 1fr; gap: 16px; }
    .services-grid { grid-template-columns: 1fr; }
    .contact-cta { padding: 80px 24px; }
  }
  @media (max-width: 600px) {
    .clients-grid { grid-template-columns: 1fr; }
  }
</style>
