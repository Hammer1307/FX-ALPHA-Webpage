---
import { pathMap, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Aktuellen Pfad mit Trailing-Slash normalisieren
const currentPath = Astro.url.pathname.replace(/\/$/, '') + '/';

// Finde den Schlüssel zum aktuellen Pfad
const matchedKey = Object.entries(pathMap).find(([_, paths]) => paths[lang] === currentPath)?.[0];

// Pfade für beide Sprachen
const dePath = matchedKey ? pathMap[matchedKey].de : '/de/';
const enPath = matchedKey ? pathMap[matchedKey].en : '/en/';
---
<div class="lang-switch" role="group" aria-label="Sprache wählen">
  <a href={dePath} class:list={['lang-btn', { active: lang === 'de' }]} data-lang="de">DE</a>
  <a href={enPath} class:list={['lang-btn', { active: lang === 'en' }]} data-lang="en">EN</a>
</div>

<style>
  /* a-Element statt button: gleiche Optik */
  .lang-btn {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }
</style>
