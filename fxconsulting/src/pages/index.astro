---
// Sprachweiche auf der Root-URL.
// Erkennt Browser-Sprache und leitet auf /de/ oder /en/ weiter.
// Kanonische Domain wird aus astro.config.mjs (Astro.site) abgeleitet —
// KEINE fest verdrahtete Fremddomain mehr. Das Canonical der Root verweist
// auf die deutsche Hauptseite /de/ (x-default); dorthin konsolidiert auch
// der 301 in public/_redirects.
const siteUrl = Astro.site ?? new URL('https://fxconsulting.de/');
const deUrl = new URL('/de/', siteUrl).toString();
const enUrl = new URL('/en/', siteUrl).toString();
---
<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>FX Alpha — Independent Advisory for FX Trading & Electronic FX</title>
<meta name="description" content="Specialist FX advisory for banks, funds, private equity and FinTechs. eTrading, options, vendor selection, deal hedging." />
<link rel="canonical" href={deUrl} />
<link rel="alternate" hreflang="de" href={deUrl} />
<link rel="alternate" hreflang="en" href={enUrl} />
<link rel="alternate" hreflang="x-default" href={deUrl} />
<link rel="icon" type="image/png" href="/assets/favicon.png" />
<meta name="robots" content="index,follow" />
<style>
body {
  margin: 0;
  font-family: 'Manrope', -apple-system, sans-serif;
  background: #fff;
  color: #1f2d4a;
  display: grid;
  place-items: center;
  min-height: 100vh;
  padding: 24px;
}
.picker { text-align: center; max-width: 480px; }
h1 { font-family: 'Archivo', sans-serif; font-weight: 800; font-size: 28px; color: #0a1e3a; margin: 0 0 8px; letter-spacing: -0.02em; }
p { color: #3d5275; margin: 0 0 32px; }
.buttons { display: flex; gap: 12px; justify-content: center; }
.buttons a {
  padding: 14px 36px;
  background: #2563eb;
  color: #fff;
  text-decoration: none;
  border-radius: 8px;
  font-weight: 600;
  transition: background .2s;
}
.buttons a:hover { background: #1e4fc0; }
.buttons a.secondary { background: #fff; color: #0a1e3a; border: 1px solid #dbe3ed; }
.buttons a.secondary:hover { background: #f4f7fb; }
</style>
</head>
<body>
<div class="picker">
  <h1>FX Alpha</h1>
  <p>Choose your language · Sprache wählen</p>
  <div class="buttons">
    <a href="/de/">Deutsch</a>
    <a href="/en/" class="secondary">English</a>
  </div>
</div>
<script is:inline>
// Auto-Redirect basierend auf Browser-Sprache
(function () {
  try {
    var lang = (navigator.language || navigator.userLanguage || 'de').toLowerCase();
    var target = lang.indexOf('de') === 0 ? '/de/' : '/en/';
    window.location.replace(target);
  } catch (e) {
    // Fallback: User wählt manuell über die Buttons
  }
})();
</script>
</body>
</html>
