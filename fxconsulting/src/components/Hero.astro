---
interface Props {
  eyebrow?: string;
  headline: string;
  subheadline?: string;
  variant?: 'centered' | 'split';
}
const { eyebrow, headline, subheadline, variant = 'split' } = Astro.props;
---
<section class={variant === 'centered' ? 'hero' : 'page-hero'}>
  <div class="page-hero-inner">
    {eyebrow && (
      <div class="eyebrow">
        <span class="dot"></span>
        {eyebrow}
      </div>
    )}
    <h1 class="display" set:html={headline}></h1>
    {subheadline && <p class="lede" set:html={subheadline}></p>}
    <slot />
  </div>
</section>

<style>
  .page-hero {
    padding: 160px 32px 80px;
    background:
      radial-gradient(900px 600px at 50% 0%, rgba(37,99,235,.07), transparent 70%),
      var(--bg, #fff);
  }
  .page-hero-inner {
    max-width: 900px;
    margin: 0 auto;
  }
  .page-hero .eyebrow { margin-bottom: 24px; }
  .page-hero .display { font-size: clamp(36px, 4.8vw, 60px); margin-bottom: 24px; }
  .page-hero .lede { max-width: 720px; margin-bottom: 0; }

  @media (max-width: 980px) {
    .page-hero { padding: 120px 24px 60px; }
  }
</style>
